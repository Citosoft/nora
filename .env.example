# OAuth app client IDs for forge integrations
NORA_GITHUB_CLIENT_ID=
NORA_GITLAB_CLIENT_ID=
NORA_VERCEL_CLIENT_ID=
NORA_GITHUB_CLIENT_SECRET=
NORA_GITLAB_CLIENT_SECRET=
NORA_VERCEL_CLIENT_SECRET=

# Optional host overrides
# NORA_GITHUB_OAUTH_HOST=github.com
# NORA_GITLAB_OAUTH_HOST=gitlab.com
# NORA_VERCEL_OAUTH_HOST=vercel.com

# Fixed OAuth callback used by the desktop app
# Register: http://127.0.0.1:45871/oauth/callback
# NORA_OAUTH_CALLBACK_HOST=127.0.0.1
# NORA_OAUTH_CALLBACK_PORT=45871

# PostHog analytics (optional; leave empty to disable)
# NORA_POSTHOG_API_KEY=
# NORA_POSTHOG_HOST=https://eu.i.posthog.com
# VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=
# VITE_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
