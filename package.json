{
  "name": "nora",
  "productName": "Nora",
  "displayName": "Nora",
  "desktopName": "nora.desktop",
  "version": "0.1.44",
  "description": "Multi-agent coding workspace with PTY-backed terminals, git-aware workflows, and isolated worktrees.",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json && tsc -p tsconfig.preload.json --noEmit && node scripts/bundle-preload.mjs && node scripts/build-renderer.mjs && tailwindcss -i renderer/styles.css -o dist/renderer/styles.css && node scripts/generate-oauth-build-config.mjs && node scripts/generate-icons.mjs && node scripts/generate-third-party-notices.mjs && node scripts/copy-static.mjs",
    "generate:icons": "node scripts/generate-icons.mjs",
    "generate:third-party-notices": "node scripts/generate-third-party-notices.mjs",
    "install:linux-dev-launcher": "node scripts/install-linux-dev-launcher.mjs",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags",
    "start": "npm run build && electron .",
    "dev": "node scripts/dev.mjs",
    "dev:nogpu": "node scripts/dev.mjs --disable-gpu",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "make:darwin": "npm run build && electron-forge package --platform=darwin --arch=arm64",
    "test:unit": "tsc -p tsconfig.unit.json && tsc-alias -p tsconfig.unit.json && node scripts/runUnitTests.mjs",
    "check:path-hygiene": "node scripts/check-path-hygiene.mjs",
    "check:shell-assembly-imports": "node scripts/checkShellAssemblyImports.mjs",
    "check:nora-bridge-usage": "node scripts/checkNoraBridgeUsage.mjs"
  },
  "keywords": [
    "electron",
    "agents",
    "git",
    "orchestrator"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Citosoft/nora.git"
  },
  "author": "Citosoft",
  "license": "MIT",
  "config": {
    "forge": "./forge.config.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "^3.0.170",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@monaco-editor/react": "^4.7.0",
    "@posthog/react": "^1.9.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.168",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.511.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "posthog-js": "^1.365.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "strip-ansi": "^6.0.1",
    "tailwind-merge": "^3.3.1",
    "update-electron-app": "^3.1.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "electron": "^37.2.0",
    "electron-devtools-installer": "^4.0.0",
    "esbuild": "^0.25.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.0"
  }
}
